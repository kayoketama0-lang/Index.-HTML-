<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Kayo | Portfolio</title>
    <style>
        /* --- CSS VARIABLES & RESET --- */
        :root {
            --bg-color: #0f172a;
            --card-bg: #1e293b;
            --text-main: #f8fafc;
            --text-secondary: #94a3b8;
            --accent: #38bdf8; /* Light Blue */
            --accent-hover: #0ea5e9;
            --font-main: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            scroll-behavior: smooth;
        }

        body {
            font-family: var(--font-main);
            background-color: var(--bg-color);
            color: var(--text-main);
            line-height: 1.6;
            overflow-x: hidden;
        }

        a { text-decoration: none; color: inherit; }
        ul { list-style: none; }

        /* --- HEADER & NAVIGATION --- */
        header {
            position: fixed;
            top: 0;
            width: 100%;
            padding: 1.5rem 5%;
            display: flex;
            justify-content: space-between;
            align-items: center;
            background-color: rgba(15, 23, 42, 0.9);
            backdrop-filter: blur(10px);
            z-index: 1000;
            border-bottom: 1px solid rgba(255,255,255,0.1);
        }
        .logo {
            font-size: 1.8rem;
            font-weight: 700;
            color: var(--accent);
            letter-spacing: 2px;
        }

        nav ul {
            display: flex;
            gap: 2rem;
        }

        nav a {
            font-weight: 500;
            transition: color 0.3s;
        }

        nav a:hover {
            color: var(--accent);
        }

        .menu-toggle {
            display: none;
            font-size: 1.5rem;
            cursor: pointer;
        }

        /* --- HERO SECTION --- */
        .hero {
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
            padding: 0 5%;
        }

        .hero-content h1 {
            font-size: 4rem;
            margin-bottom: 1rem;
        }

        .hero-content span {
            color: var(--accent);
        }

        .hero-content p {
            font-size: 1.5rem;
            color: var(--text-secondary);            margin-bottom: 2rem;
            min-height: 1.6em; /* Prevent layout shift on typing */
        }

        .btn {
            display: inline-block;
            padding: 0.8rem 2rem;
            background-color: var(--accent);
            color: var(--bg-color);
            font-weight: bold;
            border-radius: 5px;
            transition: transform 0.3s, background-color 0.3s;
        }

        .btn:hover {
            background-color: var(--accent-hover);
            transform: translateY(-3px);
        }

        /* --- SECTIONS GENERAL --- */
        section {
            padding: 5rem 10%;
        }

        .section-title {
            text-align: center;
            font-size: 2.5rem;
            margin-bottom: 3rem;
        }

        .section-title span {
            border-bottom: 3px solid var(--accent);
        }

        /* --- ABOUT --- */
        .about-container {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 4rem;
            align-items: center;
        }

        .about-img {
            width: 100%;
            height: 300px;
            background-color: var(--card-bg);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;            border: 2px solid var(--accent);
            color: var(--text-secondary);
        }

        /* --- SKILLS --- */
        .skills-grid {
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            gap: 1rem;
        }

        .skill-tag {
            background-color: var(--card-bg);
            padding: 0.8rem 1.5rem;
            border-radius: 50px;
            border: 1px solid rgba(255,255,255,0.1);
            transition: 0.3s;
        }

        .skill-tag:hover {
            border-color: var(--accent);
            color: var(--accent);
            transform: scale(1.05);
        }

        /* --- PROJECTS --- */
        .projects-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 2rem;
        }

        .project-card {
            background-color: var(--card-bg);
            border-radius: 10px;
            overflow: hidden;
            transition: transform 0.3s;
            position: relative;
        }

        .project-card:hover {
            transform: translateY(-10px);
        }

        .card-img {
            height: 200px;
            background-color: #334155;
            display: flex;
            align-items: center;            justify-content: center;
            color: var(--text-secondary);
        }

        .card-info {
            padding: 1.5rem;
        }

        .card-info h3 {
            margin-bottom: 0.5rem;
            color: var(--accent);
        }

        /* --- CONTACT --- */
        .contact-form {
            max-width: 600px;
            margin: 0 auto;
            display: flex;
            flex-direction: column;
            gap: 1rem;
        }

        input, textarea {
            padding: 1rem;
            background-color: var(--card-bg);
            border: 1px solid rgba(255,255,255,0.1);
            color: var(--text-main);
            border-radius: 5px;
            font-family: inherit;
        }

        input:focus, textarea:focus {
            outline: 2px solid var(--accent);
            border-color: transparent;
        }

        /* --- FOOTER --- */
        footer {
            text-align: center;
            padding: 2rem;
            background-color: var(--card-bg);
            color: var(--text-secondary);
            margin-top: 4rem;
        }

        /* --- ANIMATIONS (Scroll Reveal) --- */
        .hidden {
            opacity: 0;
            transform: translateY(50px);
            transition: all 1s ease;        }

        .show {
            opacity: 1;
            transform: translateY(0);
        }

        /* --- RESPONSIVE DESIGN --- */
        @media (max-width: 768px) {
            .menu-toggle { display: block; }
            
            nav ul {
                position: absolute;
                top: 70px;
                right: -100%;
                width: 100%;
                background-color: var(--card-bg);
                flex-direction: column;
                text-align: center;
                padding: 2rem 0;
                transition: 0.4s;
            }

            nav ul.active {
                right: 0;
            }

            .hero-content h1 { font-size: 2.5rem; }
            
            .about-container { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>

    <!-- Header -->
    <header>
        <div class="logo">KAYO</div>
        <div class="menu-toggle" id="mobile-menu">☰</div>
        <nav>
            <ul id="nav-list">
                <li><a href="#home">Home</a></li>
                <li><a href="#about">About</a></li>
                <li><a href="#skills">Skills</a></li>
                <li><a href="#projects">Projects</a></li>
                <li><a href="#contact">Contact</a></li>
            </ul>
        </nav>
    </header>
    <!-- Hero Section -->
    <section id="home" class="hero">
        <div class="hero-content hidden">
            <h1>Hi, I'm <span>Kayo</span></h1>
            <p>I am a <span id="typing-text"></span></p>
            <a href="#projects" class="btn">View My Work</a>
        </div>
    </section>

    <!-- About Section -->
    <section id="about">
        <h2 class="section-title"><span>About Me</span></h2>
        <div class="about-container hidden">
            <div class="about-img">
                <!-- Replace with <img src="your-photo.jpg"> -->
                [ Your Photo Here ]
            </div>
            <div class="about-text">
                <h3>Who am I?</h3>
                <p>I am a passionate developer and creative thinker based in the digital world. I love building things that live on the internet. My goal is to create clean, efficient, and user-friendly experiences.</p>
                <br>
                <p>When I'm not coding, you can find me exploring new technologies, designing interfaces, or solving complex problems.</p>
            </div>
        </div>
    </section>

    <!-- Skills Section -->
    <section id="skills">
        <h2 class="section-title"><span>My Skills</span></h2>
        <div class="skills-grid hidden">
            <div class="skill-tag">HTML5</div>
            <div class="skill-tag">CSS3</div>
            <div class="skill-tag">JavaScript</div>
            <div class="skill-tag">React</div>
            <div class="skill-tag">Node.js</div>
            <div class="skill-tag">UI/UX Design</div>
            <div class="skill-tag">Git</div>
            <div class="skill-tag">Python</div>
        </div>
    </section>

    <!-- Projects Section -->
    <section id="projects">
        <h2 class="section-title"><span>Projects</span></h2>
        <div class="projects-grid">
            <!-- Project 1 -->
            <div class="project-card hidden">
                <div class="card-img">Project Image</div>
                <div class="card-info">
                    <h3>E-Commerce App</h3>                    <p>A full-stack shopping application with payment integration.</p>
                </div>
            </div>
            <!-- Project 2 -->
            <div class="project-card hidden">
                <div class="card-img">Project Image</div>
                <div class="card-info">
                    <h3>Portfolio Design</h3>
                    <p>A minimalistic portfolio template for designers.</p>
                </div>
            </div>
            <!-- Project 3 -->
            <div class="project-card hidden">
                <div class="card-img">Project Image</div>
                <div class="card-info">
                    <h3>Task Manager</h3>
                    <p>A productivity tool to manage daily tasks efficiently.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Contact Section -->
    <section id="contact">
        <h2 class="section-title"><span>Contact Me</span></h2>
        <form class="contact-form hidden">
            <input type="text" placeholder="Your Name" required>
            <input type="email" placeholder="Your Email" required>
            <textarea rows="5" placeholder="Your Message" required></textarea>
            <button type="submit" class="btn">Send Message</button>
        </form>
    </section>

    <!-- Footer -->
    <footer>
        <p>&copy; 2023 Kayo Portfolio. All rights reserved.</p>
    </footer>

    <!-- JavaScript -->
    <script>
        // 1. Mobile Menu Toggle
        const menuToggle = document.getElementById('mobile-menu');
        const navList = document.getElementById('nav-list');

        menuToggle.addEventListener('click', () => {
            navList.classList.toggle('active');
        });

        // Close menu when a link is clicked
        document.querySelectorAll('nav a').forEach(link => {            link.addEventListener('click', () => {
                navList.classList.remove('active');
            });
        });

        // 2. Typing Effect
        const textElement = document.getElementById('typing-text');
        const phrases = ['Web Developer', 'UI/UX Designer', 'Freelancer', 'Creator'];
        let phraseIndex = 0;
        let charIndex = 0;
        let isDeleting = false;

        function type() {
            const currentPhrase = phrases[phraseIndex];
            
            if (isDeleting) {
                textElement.textContent = currentPhrase.substring(0, charIndex - 1);
                charIndex--;
            } else {
                textElement.textContent = currentPhrase.substring(0, charIndex + 1);
                charIndex++;
            }

            if (!isDeleting && charIndex === currentPhrase.length) {
                isDeleting = true;
                setTimeout(type, 2000); // Pause at end of word
            } else if (isDeleting && charIndex === 0) {
                isDeleting = false;
                phraseIndex = (phraseIndex + 1) % phrases.length;
                setTimeout(type, 500); // Pause before new word
            } else {
                setTimeout(type, isDeleting ? 100 : 200);
            }
        }
        
        // Start typing effect on load
        document.addEventListener('DOMContentLoaded', type);

        // 3. Scroll Reveal Animation
        const observer = new IntersectionObserver((entries) => {
            entries.forEach((entry) => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('show');
                }
            });
        });

        const hiddenElements = document.querySelectorAll('.hidden');
        hiddenElements.forEach((el) => observer.observe(el));
    </script></body>
</html>